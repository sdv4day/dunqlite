{
    "authors": ["sdv"],
    "license": "BSL-1.0",
    "copyright": "Copyright © 2026, sdv",
    "name": "dunqlite",
    "targetType": "library",
    "targetPath": "bin",
    "description": "DunQLite is a D language UnQLite library",
    "dependencies": {
        "silly": "~>1.0.0"
    },
    "buildTypes": {
        "release": {
            "buildOptions": ["optimize", "inline"]
        }
    },
    "configurations": [
        {
            "name": "library",
            "targetType": "staticLibrary",
            "excludedSourceFiles": [
                "source/app.d",
                "source/app_generic.d",
                "source/benchmark.d"
            ]
        },
        {
            "name": "demo1",
            "targetType": "executable",
            "targetName": "app",
            "mainSourceFile": "source/app.d"
        },
        {
            "name": "demo-generic",
            "targetType": "executable",
            "targetName": "app_generic",
            "mainSourceFile": "source/app_generic.d"
        },
        {
            "name": "benchmark",
            "targetType": "executable",
            "targetName": "benchmark",
            "mainSourceFile": "source/benchmark.d"
        }
    ]
}
